---
import type { CollectionEntry } from 'astro:content';

interface Props {
	article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
---

<a class="story-card" href={`/articles/${article.id}/`}>
	<div class="story-card__art">
		{
			article.data.heroImage ? (
				<img src={article.data.heroImage.src} alt={article.data.heroImage.alt} loading="lazy" />
			) : (
				<div style="width:100%;height:100%;display:grid;place-items:center;font-family:var(--font-mono);font-size:.8rem;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-soft);">
					Render pending
				</div>
			)
		}
	</div>
	<div class="story-card__meta">
		<span>{article.data.publishDate.toLocaleDateString('en-US', { dateStyle: 'medium' })}</span>
		<span>{article.data.references.length} references</span>
	</div>
	<h3 class="story-card__title">{article.data.title}</h3>
	<p class="story-card__excerpt">{article.data.excerpt}</p>
	<ul class="tag-list">
		{article.data.tags.slice(0, 4).map((tag) => <li>{tag}</li>)}
	</ul>
</a>
